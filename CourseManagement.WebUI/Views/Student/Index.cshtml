
@model List<StudentDto>

@{
    ViewData["Title"] = "Index";
}

<h3>Students</h3>
<a class="btn btn-success" asp-action="Create">Create</a>
<table class="table">
    <thead>
        <tr>
            <th>Id</th>
            <th>FullName</th>
            <th>Email</th>
            <th>Action</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.FullName</td>
                <td>@item.Email</td>
                <td><a class="btn btn-sm btn-warning" asp-action="AssignCourse" asp-route-id="@item.Id">Assign Course</a>
                    <a class="btn btn-sm btn-info" asp-action="Detail" asp-route-id="@item.Id">Detail</a> |
                    <a class="btn btn-sm btn-primary" asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                    <a class="btn btn-sm btn-danger" asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                    </td>
            </tr>
        }


    </tbody>
</table>

