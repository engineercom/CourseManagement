@model List<CourseDto>
@{
    ViewData["Title"] = "Index";
}
<a class="btn btn-success" asp-action="Create">Create</a>
<table class="table">
    <tr>
        <th>Id</th>
        <th>Title</th>
        <th>Price</th>
        <th>Action</th>

    </tr>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Id</td>
            <td>@item.Name</td>
            <td>@item.Price</td>
            <td>
                <a class="btn btn-sm btn-primary me-2" asp-action="Edit" asp-route-id="@item.Id">
                    Edit
                </a> |
                <a class="btn btn-sm btn-danger" asp-action="Delete" asp-route-id="@item.Id">
                    Delete
                    </a>
            </td>
        </tr>
    }
</table>

